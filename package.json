{
  "name": "@b_niamin/workflow",
  "version": "1.1.0",
  "description": "A TypeScript-based implementation of a Petri net workflow, with guards.",
  "packageManager": "pnpm@10.17.0",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "workflow",
    "petri net",
    "typescript",
    "business rules",
    "business guards",
    "state machine"
  ],
  "author": "Piotr Liszka https://github.com/piotr-liszka",
  "scripts": {
    "test": "jest",
    "test-with-coverage": "jest --coverage",
    "prettier": "prettier -c ./",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm run clean && pnpm run build-cjs && pnpm run build-esm && pnpm run build-post",
    "build-cjs": "tsc -p tsconfig.cjs.json",
    "build-esm": "tsc -p tsconfig.esm.json",
    "build-post": "node scripts/fix-esm-extensions.mjs && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json && echo '{\"type\":\"module\"}' > dist/esm/package.json",
    "publish:ci": "npm publish --provenance --access public"
  },
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/piotr-liszka/workflow.git"
  },
  "bugs": {
    "url": "https://github.com/piotr-liszka/workflow/issues"
  },
  "homepage": "https://github.com/piotr-liszka/workflow#readme"
}
